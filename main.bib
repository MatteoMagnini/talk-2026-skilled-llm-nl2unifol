@article{SirocchiBMC,
	abstract = {Clinical medicine offers a promising arena for applying Machine Learning (ML) models. However, despite numerous studies employing ML in medical data analysis, only a fraction have impacted clinical care. This article underscores the importance of utilising ML in medical data analysis, recognising that ML alone may not adequately capture the full complexity of clinical data, thereby advocating for the integration of medical domain knowledge in ML.},
	author = {Sirocchi, Christel and Bogliolo, Alessandro and Montagna, Sara},
